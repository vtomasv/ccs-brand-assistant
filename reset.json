{
  "run": [
    {
      "method": "log",
      "params": {
        "html": "<p>&#x1F5D1;&#xFE0F; Desinstalando CCS Brand Assistant...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "rm -rf venv",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "notify",
      "params": {
        "html": "CCS Brand Assistant desinstalado. Los datos del usuario se conservan en la carpeta 'data'.",
        "type": "info"
      }
    }
  ]
}
