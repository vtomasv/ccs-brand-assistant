{
  "daemon": true,
  "run": [
    {
      "method": "log",
      "params": {
        "html": "<p>&#x25B6;&#xFE0F; Iniciando Ollama en segundo plano...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'powershell -ExecutionPolicy Bypass -File scripts\\\\start_ollama.ps1' : 'ollama serve > /dev/null 2>&1 & sleep 4'}}",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "log",
      "params": {
        "html": "<p>&#x1F680; Iniciando servidor CSS Brand Assistant en puerto {{port}}...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\python.exe server/app.py' : 'venv/bin/python server/app.py'}}",
        "path": "{{cwd}}",
        "env": {
          "PORT": "{{port}}",
          "DATA_DIR": "{{cwd}}/data",
          "OLLAMA_URL": "http://localhost:11434",
          "PYTHONIOENCODING": "utf-8",
          "PYTHONUTF8": "1"
        }
      }
    }
  ]
}
