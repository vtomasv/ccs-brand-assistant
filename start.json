{
  "daemon": true,
  "run": [
    {
      "when": "{{platform !== 'win32'}}",
      "method": "shell.run",
      "params": {
        "message": "ollama serve > /dev/null 2>&1 &"
      }
    },
    {
      "when": "{{platform === 'win32'}}",
      "method": "shell.run",
      "params": {
        "message": "start /B ollama serve"
      }
    },
    {
      "when": "{{platform === 'win32'}}",
      "method": "shell.run",
      "params": {
        "env": {
          "PYTHONIOENCODING": "utf-8",
          "PYTHONUTF8": "1"
        },
        "message": "venv\\Scripts\\python.exe server/app.py --port {{port}}",
        "on": [{ "event": "/(http:\\/\\/[0-9.:]+)/", "done": true }]
      }
    },
    {
      "when": "{{platform !== 'win32'}}",
      "method": "shell.run",
      "params": {
        "env": {
          "PYTHONIOENCODING": "utf-8",
          "PYTHONUTF8": "1"
        },
        "message": "venv/bin/python server/app.py --port {{port}}",
        "on": [{ "event": "/(http:\\/\\/[0-9.:]+)/", "done": true }]
      }
    },
    {
      "method": "self.set",
      "params": {
        "session.json": {
          "url": "{{input.event[0]}}"
        }
      }
    },
    {
      "method": "browser.open",
      "params": {
        "uri": "{{self.session.url}}/ui/index.html"
      }
    }
  ]
}
