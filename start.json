{
  "daemon": true,
  "run": [
    {
      "method": "log",
      "params": {
        "html": "<p>&#x25B6;&#xFE0F; Iniciando CCS Brand Assistant...</p><p style='color:#888;font-size:12px'>Plataforma: <strong>{{platform}}</strong></p>"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<p>&#x1F99B; Iniciando Ollama en segundo plano (opcional)...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'powershell -ExecutionPolicy Bypass -File scripts\\\\start_ollama.ps1' : 'ollama serve > /dev/null 2>&1 & sleep 4 && echo OLLAMA_STARTED'}}",
        "path": "{{cwd}}",
        "on": [
          {
            "event": "/ERROR|error/i",
            "done": false
          }
        ]
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<p>&#x1F680; Iniciando servidor CCS Brand Assistant en puerto {{port}}...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\python.exe server/app.py' : 'venv/bin/python server/app.py'}}",
        "path": "{{cwd}}",
        "env": {
          "PORT": "{{port}}",
          "DATA_DIR": "{{cwd}}/data",
          "OLLAMA_URL": "http://localhost:11434",
          "PYTHONIOENCODING": "utf-8",
          "PYTHONUTF8": "1"
        },
        "on": [
          {
            "event": "/Uvicorn running|Application startup complete|Started server/i",
            "done": true
          }
        ]
      }
    }
  ]
}
