{
  "daemon": true,
  "run": [
    {
      "method": "log",
      "params": {
        "html": "<p>&#x25B6;&#xFE0F; Iniciando CCS Brand Assistant en puerto {{port}}...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "ollama serve > /dev/null 2>&1 & sleep 3 && python server/app.py",
        "path": "{{cwd}}",
        "venv": "venv",
        "env": {
          "PORT": "{{port}}",
          "DATA_DIR": "{{cwd}}/data",
          "OLLAMA_URL": "http://127.0.0.1:11434",
          "PYTHONIOENCODING": "utf-8",
          "PYTHONUTF8": "1"
        }
      }
    }
  ]
}
