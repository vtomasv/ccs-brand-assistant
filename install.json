{
  "run": [
    {
      "method": "log",
      "params": {
        "html": "<div style='padding:20px'><h2>&#x1F680; Instalando CCS Brand Assistant</h2><p style='color:#555'>Plataforma: <strong>{{platform}}</strong> &nbsp;|&nbsp; RAM: <strong>{{ram}}GB</strong></p><p style='color:#888;font-size:13px'>Este proceso puede tomar 5-15 minutos la primera vez.</p></div>"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<p style='padding:0 20px'>&#x1F50D; <strong>Paso 1/6</strong> &mdash; Verificando Ollama...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "ollama --version 2>/dev/null && echo OLLAMA_OK || curl -fsSL https://ollama.com/install.sh | sh",
        "path": "{{cwd}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<p style='padding:0 20px'>&#x25B6;&#xFE0F; <strong>Paso 2/6</strong> &mdash; Iniciando servicio Ollama...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "ollama serve > /dev/null 2>&1 &",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "sleep 5 && curl -s http://localhost:11434/api/tags > /dev/null && echo OLLAMA_READY",
        "path": "{{cwd}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<p style='padding:0 20px'>&#x2B07;&#xFE0F; <strong>Paso 3/6</strong> &mdash; Descargando modelo de IA (RAM: {{ram}}GB)...</p><p style='padding:0 20px;color:#888;font-size:12px'>Esto puede tardar varios minutos dependiendo de tu conexi&#xF3;n.</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{ram < 6 ? 'ollama pull llama3.2:1b' : ram < 12 ? 'ollama pull llama3.2:3b' : 'ollama pull llama3.1:8b'}}",
        "path": "{{cwd}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<p style='padding:0 20px'>&#x1F40D; <strong>Paso 4/6</strong> &mdash; Creando entorno Python aislado...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "python -m venv venv --clear",
        "path": "{{cwd}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<p style='padding:0 20px'>&#x1F4E6; <strong>Paso 5/6</strong> &mdash; Instalando dependencias del servidor...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\pip.exe' : './venv/bin/pip'}} install --upgrade pip --quiet",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\pip.exe' : './venv/bin/pip'}} install -r requirements-core.txt",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\pip.exe' : './venv/bin/pip'}} install playwright>=1.40.0 --quiet",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\playwright.exe' : './venv/bin/playwright'}} install chromium",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\pip.exe' : './venv/bin/pip'}} install torch --index-url https://download.pytorch.org/whl/cpu --quiet",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\pip.exe' : './venv/bin/pip'}} install diffusers>=0.30.0 transformers>=4.40.0 accelerate>=0.30.0 safetensors>=0.4.0 --quiet",
        "path": "{{cwd}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<p style='padding:0 20px'>&#x1F4BE; <strong>Paso 6/6</strong> &mdash; Inicializando datos...</p>"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\python.exe' : './venv/bin/python'}} -c \"import os; [os.makedirs(d, exist_ok=True) for d in ['data/agents','data/prompts/system','data/sessions','data/exports','data/brands','data/campaigns','data/audit','data/images']]; print('DIRS_OK')\"",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\python.exe' : './venv/bin/python'}} -c \"import os, shutil; src='defaults/agents.json'; dst='data/agents/agents.json'; shutil.copy2(src, dst) if not os.path.exists(dst) else None; print('AGENTS_OK')\"",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\python.exe' : './venv/bin/python'}} -c \"import os, shutil, glob; [shutil.copy2(f, 'data/prompts/system/') for f in glob.glob('defaults/prompts/*.md') if not os.path.exists('data/prompts/system/' + os.path.basename(f))]; print('PROMPTS_OK')\"",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "fs.write",
      "params": {
        "path": "data/config.json",
        "text": "{{JSON.stringify({version:'0.2.0',installedAt:new Date().toISOString(),platform:platform,ram:ram,default_model:ram<6?'llama3.2:1b':ram<12?'llama3.2:3b':'llama3.1:8b',image_provider:'auto',diffusion_model:'SimianLuo/LCM_Dreamshaper_v7',diffusion_steps:4},null,2)}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<div style='padding:20px;background:#f0faf4;border-radius:8px;margin:16px 20px;border-left:4px solid #3DAE2B'><h3 style='color:#3DAE2B;margin-bottom:8px'>&#x2705; Instalaci&#xF3;n completada</h3><p>Haz click en <strong>Iniciar</strong> para comenzar a usar CCS Brand Assistant.</p></div>"
      }
    },
    {
      "method": "notify",
      "params": {
        "html": "CCS Brand Assistant instalado correctamente. Haz click en Iniciar."
      }
    }
  ]
}
